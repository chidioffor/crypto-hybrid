# Copy this file to .env and replace the placeholder values before running the stack.
# Secrets should be generated per environment (e.g. `openssl rand -hex 32`).

# Environment
NODE_ENV=development
APP_VERSION=1.0.0

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=cryptohybridbank
POSTGRES_USER=cryptohybrid
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://cryptohybrid:change-me@postgres:5432/cryptohybridbank

# MongoDB
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_DB=cryptohybrid
MONGODB_USER=cryptohybrid
MONGODB_PASSWORD=change-me
MONGODB_URI=mongodb://cryptohybrid:change-me@mongodb:27017/cryptohybrid?authSource=admin

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me
REDIS_URL=redis://:change-me@redis:6379/0
CARD_PROVISION_TOKEN_TTL=300

# Authentication & encryption
JWT_SECRET=replace-with-jwt-secret
WALLET_ENCRYPTION_KEY=base64-encoded-32-byte-key
CARD_DATA_ENCRYPTION_KEY=base64-encoded-32-byte-key
ALLOWED_ORIGINS=http://localhost:3005

# Service discovery
API_GATEWAY_URL=http://api-gateway:3000
USER_SERVICE_URL=http://user-service:3001
WALLET_SERVICE_URL=http://wallet-service:3002
PAYMENT_SERVICE_URL=http://payment-service:3003
CARD_SERVICE_URL=http://card-service:3004

# Frontend
REACT_APP_API_URL=http://localhost:3000

# Third-party integrations (replace before production)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
FIREBLOCKS_API_KEY=
FIREBLOCKS_SECRET_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CHAINALYSIS_API_KEY=
COLUMN_API_KEY=
MARQETA_API_KEY=
ETHEREUM_RPC_URL=
POLYGON_RPC_URL=
BSC_RPC_URL=
PRIVATE_KEY=

# Monitoring
GRAFANA_ADMIN_PASSWORD=change-me

# Email (optional)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
